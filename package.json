{
  "name": "daily-noti-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/bot/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/bot/index.js",
    "db:init": "tsx src/storage/migrate.ts",
    "schedule:alerts": "tsx src/schedulers/check-alerts.ts",
    "schedule:daily": "tsx src/schedulers/send-daily-updates.ts",
    "worker:cron": "tsx src/schedulers/local-cron.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "@libsql/client": "^0.17.0",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
    "grammy": "^1.30.0",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.6"
  }
}
