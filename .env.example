BOT_TOKEN=
NODE_ENV=development
LOG_LEVEL=info

DATABASE_PATH=

# Local SQLite-compatible file by default. Use libsql://... plus DATABASE_AUTH_TOKEN
# for GitHub Actions or any environment that cannot share a local database file.
DATABASE_URL=
DATABASE_AUTH_TOKEN=

ADMIN_USER_IDS=
DEFAULT_CURRENCY=USD
PRICE_CACHE_TTL_SECONDS=120
HTTP_TIMEOUT_MS=10000
MAX_ALERTS_PER_USER=20

# Price sources.
GOLD_API_BASE_URL=https://api.gold-api.com
GOLD_API_KEY=
GOLD_API_KEY_HEADER=x-access-token
GOLD_PROVIDERS_ENABLED=sjc,mihong,doji,pnj,global
GOLD_PROVIDER_FALLBACK_ORDER=mihong,sjc,pnj,doji,global
GOLD_PROVIDER_RETRY_COUNT=2
GOLD_PROVIDER_HEADERS_JSON=
SJC_GOLD_API_URL=
SJC_GOLD_SOURCE_URLS=https://giavang.now/api/prices?type=SJL1L10,https://www.vang.today/api/prices?type=SJL1L10
SJC_GOLD_HTML_URL=https://sjc.com.vn/
MIHONG_DOMESTIC_GOLD_API_URL=https://api.mihong.vn/v1/gold-prices?market=domestic
MIHONG_GOLD_HTML_URL=https://www.mihong.vn/
DOJI_GOLD_API_URL=
DOJI_GOLD_HTML_URL=https://giavang.doji.vn/
PNJ_GOLD_API_URL=
PNJ_GOLD_SOURCE_URLS=https://giavang.now/api/prices?type=PQHNVM,https://giavang.now/api/prices?type=PQHN24NTT,https://www.vang.today/api/prices?type=PQHNVM,https://www.vang.today/api/prices?type=PQHN24NTT
PNJ_GOLD_HTML_URL=https://www.pnj.com.vn/blog/gia-vang/
GLOBAL_GOLD_API_URL=https://api.mihong.vn/v1/gold-prices?market=global
GLOBAL_GOLD_HTML_URL=https://www.mihong.vn/
EIA_API_BASE_URL=https://api.eia.gov
EIA_API_KEY=

# Scheduling.
DAILY_UPDATE_TIMEZONE=Asia/Ho_Chi_Minh
DAILY_UPDATE_CRON=0 7 * * *
ALERT_CHECK_CRON=*/15 * * * *

# Optional notification mirror.
DISCORD_WEBHOOK_URL=
