BOT_TOKEN=
NODE_ENV=development
LOG_LEVEL=info

# Optional admin users, comma-separated Telegram user IDs.
ADMIN_USER_IDS=

# Neon Postgres connection string.
# Example: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=YOUR_NEON_POSTGRES_DATABASE_URL

# Telegram webhook settings for Vercel.
TELEGRAM_WEBHOOK_URL=https://daily-noti-bot.vercel.app/api/telegram
TELEGRAM_WEBHOOK_SECRET=

# Optional API keys.
GOLD_API_KEY=
EIA_API_KEY=

# Optional provider overrides.
SJC_GOLD_API_URL=
DOJI_GOLD_API_URL=
PNJ_GOLD_API_URL=
GOLD_PROVIDER_HEADERS_JSON=

# Optional notification mirror.
DISCORD_WEBHOOK_URL=
